APP_ENV=local
HOST=127.0.0.1
PORT=8000
DATABASE_URL=postgresql+asyncpg://summarix:summarix@localhost:5432/summarix
DATABASE_AUTO_CREATE_TABLES=true
# 启动前请替换为至少 32 个字符的强随机密钥
JWT_SECRET_KEY=please-change-this-secret
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax
BROWSER_EXTENSION_ORIGINS=
CHAT_AGENT_MODE=mock
CHAT_ARTIFACT_ROOT=.data/artifacts
CHAT_MAX_ARTIFACT_BYTES=8388608
DEFAULT_CHAT_MODEL=qwen3.5-flash
TEXT_SUMMARY_MODEL=qwen3.5-flash
VISION_ANALYSIS_MODEL=qwen3.5-flash
CONVERSATION_MODEL=qwen3.5-flash
# 默认使用 DATABASE_URL 保存 ADK 会话；需要独立库时再设置 ADK_DATABASE_URL
# ADK_DATABASE_URL=postgresql+asyncpg://summarix:summarix@localhost:5432/summarix_adk
