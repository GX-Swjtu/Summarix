# 直接本地开发时，可把模型 Key 放在 .env；使用 make monitor-up 时，更推荐把第三方 Key 放到 .env.api.key。
# 根目录 .env 用于本地直接启动 FastAPI 后端。
# 第三方模型 Key 更推荐放到 .env.api.key；执行 make monitor-up 时脚本会自动合并。

# ====================
# 常用修改
# ====================

# APP_ENV：用途：标记后端运行环境，并影响开发期浏览器插件来源的自动放行逻辑；可选值：任意字符串，项目把 local、development、dev 视为开发环境，其它通常按非开发环境处理；默认值：代码默认 local。根目录 .env 默认用于宿主机本地开发，因此模板默认 local。
APP_ENV=local

# APP_RELOAD：用途：显式控制后端是否启用 Uvicorn 热重载；可选值：true、false；默认值：代码默认空，留空时 local、development、dev 自动开启，其它环境关闭。宿主机本地开发通常留空；deploy/backend 容器会在 Compose 中强制设为 false。
# APP_RELOAD=false

# HOST：用途：指定后端监听地址；可选值：合法 IP 或主机名，本地开发通常用 127.0.0.1，容器/生产通常用 0.0.0.0；默认值：代码默认 127.0.0.1。
HOST=127.0.0.1

# PORT：用途：指定后端监听端口；可选值：1 到 65535 的整数；默认值：代码默认 8000。
PORT=8000

# LOG_FORMAT：用途：控制日志输出格式；可选值：text、json；默认值：代码默认 text。
LOG_FORMAT=text

# LOG_LEVEL：用途：控制日志级别；可选值：标准日志级别字符串，如 DEBUG、INFO、WARNING、ERROR、CRITICAL，程序会自动转大写；默认值：代码默认 INFO。
LOG_LEVEL=INFO

# DATABASE_URL：用途：指定业务数据库连接串，后端启动必须能连上它；可选值：SQLAlchemy 支持的数据库 URL，本项目当前主要使用 postgresql+asyncpg://...；默认值：无，必须手动填写。
DATABASE_URL=postgresql+asyncpg://db_user:db_password@db.example.com:5432/summarix

# DATABASE_AUTO_CREATE_DATABASE：用途：数据库不存在时是否尝试自动建库；可选值：true、false；默认值：代码默认 true。
DATABASE_AUTO_CREATE_DATABASE=true

# DATABASE_AUTO_CREATE_TABLES：用途：后端启动后是否自动执行 Alembic 升级到最新版本；可选值：true、false；默认值：代码默认 true。生产多实例部署建议先用 make db-upgrade 或 CI/CD 单独完成升级，再启动或扩容服务。
DATABASE_AUTO_CREATE_TABLES=true

# JWT_SECRET_KEY：用途：签发和校验登录令牌的主密钥；可选值：至少 32 个字符的强随机字符串；默认值：代码默认是弱占位值，必须替换后才能启动。
JWT_SECRET_KEY=please-change-this-secret

# ACCESS_TOKEN_MINUTES：用途：Access Token 有效期，单位分钟；可选值：正整数；默认值：代码默认 15。
ACCESS_TOKEN_MINUTES=15

# REFRESH_TOKEN_DAYS：用途：Refresh Token 有效期，单位天；可选值：正整数；默认值：代码默认 30。
REFRESH_TOKEN_DAYS=30

# AUTH_COOKIE_SECURE：用途：是否只允许通过 HTTPS 发送认证 Cookie；可选值：true、false；默认值：代码默认 false，本地 HTTP 开发保持 false，生产 HTTPS 建议改为 true。
AUTH_COOKIE_SECURE=false

# AUTH_COOKIE_SAMESITE：用途：控制认证 Cookie 的 SameSite 策略；可选值：lax、strict、none；默认值：代码默认 lax。
AUTH_COOKIE_SAMESITE=lax

# CORS_ALLOW_ORIGINS：用途：允许访问后端的 Web 前端来源列表；可选值：JSON 数组或逗号分隔字符串；默认值：代码默认 ["http://localhost:5173","http://127.0.0.1:5173"]。兼容 uv --env-file 的逗号分隔写法，例如 http://localhost:5173,http://127.0.0.1:5173。
CORS_ALLOW_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]

# BROWSER_EXTENSION_ORIGINS：用途：允许访问后端的浏览器插件来源列表；可选值：JSON 数组或逗号分隔字符串，成员需是 chrome-extension://<32位ID> 或 moz-extension://<UUID>；默认值：代码默认空列表。
BROWSER_EXTENSION_ORIGINS=[]

# CHAT_AGENT_MODE：用途：选择聊天执行模式；可选值：mock（不调用真实模型，便于联调）、adk（调用真实 ADK/LiteLLM）；默认值：代码默认 adk，本模板填 mock 方便无 Key 时先跑通流程。
CHAT_AGENT_MODE=mock

# DEFAULT_CHAT_MODEL：用途：默认聊天与任务模型；可选值：LiteLLM provider/model 形式，例如 dashscope/qwen3.5-flash、openai/gpt-4o-mini；默认值：代码默认 dashscope/qwen3.5-flash。
DEFAULT_CHAT_MODEL=dashscope/qwen3.5-flash

# MODEL_CATALOG_FILE：用途：从 JSON 文件加载用户可选模型清单和建议问题模型配置；可选值：合法 JSON 文件路径；默认值：代码默认空。available_models 的顺序就是前端菜单顺序，第一个模型会作为默认主力模型；suggested_questions_model 用于后台建议问题生成，不展示给用户。可参考 config/model-catalog.example.json。
MODEL_CATALOG_FILE=config/model-catalog.example.json

# MODEL_ASSET_ROOT：用途：为模型菜单图标提供统一本地目录；可选值：合法目录路径；默认值：代码默认 iconResources。JSON 中的 icon_url 若填写相对路径，例如 qwen-color.svg 或 iconResources/qwen-color.svg，后端会自动把它转换成前端可访问的 URL。
MODEL_ASSET_ROOT=iconResources

# MODEL_CATALOG_JSON：用途：兼容旧方式，直接通过环境变量内联 JSON 配置用户可选模型清单；可选值：JSON 数组，或包含 available_models / models 数组的 JSON 对象；默认值：代码默认空。若同时设置 MODEL_CATALOG_FILE，优先使用文件配置。
# MODEL_CATALOG_JSON=

# TEXT_SUMMARY_MODEL：用途：网页总结任务专用模型；可选值：LiteLLM provider/model；默认值：代码默认空，留空时回退 DEFAULT_CHAT_MODEL；本模板显式填了同款模型。
TEXT_SUMMARY_MODEL=dashscope/qwen3.5-flash

# CONVERSATION_MODEL：用途：通用对话任务专用模型；可选值：LiteLLM provider/model；默认值：代码默认空，留空时回退 DEFAULT_CHAT_MODEL；本模板显式填了同款模型。
CONVERSATION_MODEL=dashscope/qwen3.5-flash

# XIAOHONGSHU_MODEL：用途：小红书文案任务专用模型；可选值：LiteLLM provider/model，若任务会携带截图，请确认模型支持图像输入；默认值：代码默认空，留空时回退 DEFAULT_CHAT_MODEL；本模板显式填了同款模型。
XIAOHONGSHU_MODEL=dashscope/qwen3.5-flash

# SHORT_VIDEO_SCRIPT_MODEL：用途：短视频脚本任务专用模型；可选值：LiteLLM provider/model，若任务会携带截图，请确认模型支持图像输入；默认值：代码默认空，留空时回退 DEFAULT_CHAT_MODEL；本模板显式填了同款模型。
SHORT_VIDEO_SCRIPT_MODEL=dashscope/qwen3.5-flash

# SUGGESTED_QUESTIONS_MODEL：用途：下一步建议问题任务专用模型；可选值：LiteLLM provider/model；默认值：代码默认空，留空时回退 DEFAULT_CHAT_MODEL；本模板显式填了同款模型。
SUGGESTED_QUESTIONS_MODEL=dashscope/qwen3.5-flash

# TEXT_SUMMARY_THINKING_MODE：用途：控制网页总结任务是否向 LiteLLM 传递 enable_thinking；可选值：default、enabled、disabled；默认值：代码默认 default。
TEXT_SUMMARY_THINKING_MODE=default

# CONVERSATION_THINKING_MODE：用途：控制通用对话任务是否向 LiteLLM 传递 enable_thinking；可选值：default、enabled、disabled；默认值：代码默认 default。
CONVERSATION_THINKING_MODE=default

# XIAOHONGSHU_THINKING_MODE：用途：控制小红书文案任务是否向 LiteLLM 传递 enable_thinking；可选值：default、enabled、disabled；默认值：代码默认 default。
XIAOHONGSHU_THINKING_MODE=default

# SHORT_VIDEO_SCRIPT_THINKING_MODE：用途：控制短视频脚本任务是否向 LiteLLM 传递 enable_thinking；可选值：default、enabled、disabled；默认值：代码默认 default。
SHORT_VIDEO_SCRIPT_THINKING_MODE=default

# SUGGESTED_QUESTIONS_THINKING_MODE：用途：控制建议问题任务是否向 LiteLLM 传递 enable_thinking；可选值：default、enabled、disabled；默认值：代码默认 disabled。
SUGGESTED_QUESTIONS_THINKING_MODE=disabled

# ====================
# 不常用修改
# ====================

# TRACE_ID_HEADER：用途：指定请求链路追踪 ID 使用的 HTTP Header 名称；可选值：任意合法 Header 名称；默认值：代码默认 X-Trace-ID。
TRACE_ID_HEADER=X-Trace-ID

# JWT_ALGORITHM：用途：指定 JWT 签名算法；可选值：项目当前默认使用 HS256，若要更换需确保签发与校验逻辑一致；默认值：代码默认 HS256。
JWT_ALGORITHM=HS256

# CHAT_ARTIFACT_ROOT：用途：指定上传附件与中间产物的本地落盘目录；可选值：合法相对或绝对路径；默认值：代码默认 .data/artifacts。
CHAT_ARTIFACT_ROOT=.data/artifacts

# CHAT_MAX_ARTIFACT_BYTES：用途：限制单个附件的最大字节数；可选值：正整数，单位字节；默认值：代码默认 8388608，即 8 MiB。
CHAT_MAX_ARTIFACT_BYTES=8388608

# ADK_DATABASE_URL：用途：为 ADK 会话持久化单独指定数据库；可选值：合法数据库 URL；默认值：代码默认空，留空时回退 DATABASE_URL。
# ADK_DATABASE_URL=postgresql+asyncpg://db_user:db_password@db.example.com:5432/summarix_adk

# SUMMARIX_POSTGRES_DB：用途：使用 make monitor-up 或 make monitor-backend-up LOCAL_DB=1 时，为共享 PostgreSQL 指定数据库名；可选值：任意合法数据库名；默认值：监控脚本默认 summarix。
SUMMARIX_POSTGRES_DB=summarix

# SUMMARIX_POSTGRES_USER：用途：使用共享 PostgreSQL 时指定数据库用户名；可选值：任意合法用户名；默认值：监控脚本默认 summarix。
SUMMARIX_POSTGRES_USER=summarix

# SUMMARIX_POSTGRES_PASSWORD：用途：使用共享 PostgreSQL 时指定数据库密码；可选值：任意非空字符串；默认值：监控脚本默认 summarix，若留空首次启动时脚本也会自动补齐持久化值。
# SUMMARIX_POSTGRES_PASSWORD=

# SUMMARIX_POSTGRES_PORT：用途：共享 PostgreSQL 暴露到宿主机的端口；可选值：1 到 65535 的整数；默认值：监控脚本默认 5432。
SUMMARIX_POSTGRES_PORT=5432

# SUMMARIX_REDIS_PORT：用途：共享 Redis 暴露到宿主机的端口；可选值：1 到 65535 的整数；默认值：监控脚本默认 6379。
SUMMARIX_REDIS_PORT=6379

# GRAFANA_ADMIN_USER：用途：本地 Grafana 管理员用户名；可选值：任意非空字符串；默认值：监控脚本和 Compose 默认 admin。
GRAFANA_ADMIN_USER=admin

# GRAFANA_ADMIN_PASSWORD：用途：本地 Grafana 管理员密码；可选值：任意非空字符串；默认值：监控脚本与 Compose 默认 please-change-me，首次启动后通常会落盘到持久化 env。
# GRAFANA_ADMIN_PASSWORD=

# PROMETHEUS_ENABLED：用途：是否在后端暴露 Prometheus 指标接口；可选值：true、false；默认值：代码默认 false；执行 make monitor-up 时脚本会自动改成 true。
PROMETHEUS_ENABLED=false

# PROMETHEUS_METRICS_PATH：用途：后端 Prometheus 指标接口路径；可选值：合法 URL Path；默认值：代码默认 /metrics。
PROMETHEUS_METRICS_PATH=/metrics

# LANGWATCH_ENABLED：用途：是否启用 LangWatch 追踪接入；可选值：true、false；默认值：代码默认 false；执行 make monitor-up 时脚本默认会开启。
LANGWATCH_ENABLED=false

# LANGWATCH_API_KEY：用途：后端把 trace 上报给 LangWatch 时使用的项目 API Key；可选值：LangWatch 项目后台签发的 sk-lw-...；默认值：代码默认空。
LANGWATCH_API_KEY=

# LANGWATCH_ENDPOINT：用途：后端向 LangWatch 发送数据时使用的内部访问地址；可选值：合法 http/https URL；默认值：代码默认空；监控脚本生成环境时默认回填 http://langwatch:5560。
LANGWATCH_ENDPOINT=http://127.0.0.1:5560

# LANGWATCH_PUBLIC_URL：用途：前端、Grafana 或用户浏览器访问 LangWatch 的公开地址；可选值：合法 http/https URL；默认值：代码默认空；监控脚本生成环境时默认回填 https://127.0.0.1:5560。
LANGWATCH_PUBLIC_URL=http://127.0.0.1:5560

# LANGWATCH_DEBUG：用途：是否开启 LangWatch 集成的调试输出；可选值：true、false；默认值：代码默认 false。
LANGWATCH_DEBUG=false

# LANGWATCH_GUARDRAILS_ENABLED：用途：是否启用 LangWatch Guardrails；可选值：true、false；默认值：代码默认 false。
LANGWATCH_GUARDRAILS_ENABLED=false

# LANGWATCH_GUARDRAILS_FAIL_OPEN：用途：Guardrails 调用异常时是否放行业务请求；可选值：true、false；默认值：代码默认 true。
LANGWATCH_GUARDRAILS_FAIL_OPEN=true

# LANGWATCH_INPUT_GUARDRAIL_SLUG：用途：指定输入侧 Guardrail 的 slug；可选值：LangWatch 中已创建规则的 slug；默认值：代码默认空。
LANGWATCH_INPUT_GUARDRAIL_SLUG=

# LANGWATCH_OUTPUT_GUARDRAIL_MODE：用途：指定输出侧 Guardrail 的执行模式；可选值：audit、block；默认值：代码默认 audit。
LANGWATCH_OUTPUT_GUARDRAIL_MODE=audit

# LANGWATCH_PROMPTS_ENABLED：用途：是否启用 LangWatch Prompt 管理；可选值：true、false；默认值：代码默认 false。
LANGWATCH_PROMPTS_ENABLED=false

# LANGWATCH_CHAT_PROMPT_HANDLE：用途：指定聊天提示词在 LangWatch Prompt 管理中的 handle；可选值：已在 LangWatch 中创建的 handle 名称；默认值：代码默认空。
LANGWATCH_CHAT_PROMPT_HANDLE=
